# ============================================================
# Prode Mundial 2026 — Variables de entorno
# Copiá este archivo a .env.local y completá los valores
# ============================================================

# Supabase — sacá estos valores de tu proyecto en supabase.com > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Service Role (para el cron y sync — NUNCA expongas esto en el frontend)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# football-data.org — registrate gratis en https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Para proteger el endpoint del cron (cualquier string secreto que elijas)
# Vercel lo agrega automáticamente como CRON_SECRET si usás Vercel Cron
CRON_SECRET=mi-secreto-super-seguro-cambiar-esto
